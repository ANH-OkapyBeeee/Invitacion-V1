rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{photoId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['url', 'status', 'createdAt', 'fileName', 'size']);
      allow update, delete: if false; // Only admin can update or delete, but since client SDK handles simple updates we'll keep rules permissive or let it be for now
    }
  }
}